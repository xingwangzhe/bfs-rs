{
  "name": "@xingwangzhe/bfs-rs",
  "version": "0.1.9",
  "description": "Rust BFS on compressed adjacency list with Rayon parallelism",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "author": "xingwangzhe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xingwangzhe/bfs-rs.git"
  },
  "keywords": [
    "bfs",
    "graph",
    "rayon",
    "napi-rs",
    "rust"
  ],
  "files": [
    "index.d.ts",
    "index.js",
    "bfs-rs.*.node"
  ],
  "napi": {
    "binaryName": "bfs-rs",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "test": "node --test bfs.test.mjs",
    "lint": "oxlint",
    "artifacts": "napi artifacts"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.3",
    "@oxc-node/core": "^0.1.0",
    "ava": "^8.0.1",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2"
  }
}
